{
  "compilerOptions": {
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "lib": ["es2022"],
    "module": "commonjs",
    "moduleResolution": "node",
    "noEmit": true,
    "resolveJsonModule": true,
    "strict": true,
    "target": "es2022",
    "types": ["node", "mocha", "chai-as-promised"]
  },
  "include": ["hardhat.config.ts", "test/**/*.ts"]
}
