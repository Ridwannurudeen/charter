{
  "name": "@charter/conformance",
  "version": "0.1.0",
  "description": "Hardhat conformance checks for Charter module ACL boundaries",
  "license": "BSD-3-Clause-Clear",
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "files": [
    "LICENSE",
    "dist",
    "README.md"
  ],
  "scripts": {
    "clean": "rimraf artifacts cache dist types",
    "compile": "hardhat compile",
    "build:ts": "tsc --project tsconfig.json",
    "prebuild": "npm run build --workspace @charter/core",
    "build": "npm run compile && npm run build:ts",
    "pretest": "npm run build --workspace @charter/core",
    "test": "npm run compile && hardhat test --no-compile test/positive.ts && node scripts/verify-broken-suite.mjs",
    "test:positive": "hardhat test test/positive.ts",
    "test:broken": "hardhat test test/broken.ts",
    "test:integrity": "node scripts/verify-broken-suite.mjs",
    "prepack": "npm run clean && npm run build"
  },
  "dependencies": {
    "@charter/core": "0.1.0"
  },
  "peerDependencies": {
    "@fhevm/hardhat-plugin": "^0.4.2",
    "@nomicfoundation/hardhat-chai-matchers": "^2.1.0",
    "@nomicfoundation/hardhat-ethers": "^3.1.3",
    "@nomicfoundation/hardhat-network-helpers": "^1.1.2",
    "chai": "^4.5.0",
    "ethers": "^6.16.0",
    "hardhat": "^2.28.6",
    "mocha": "^11.7.5"
  },
  "devDependencies": {
    "@fhevm/solidity": "0.11.1",
    "@typechain/hardhat": "^9.1.0",
    "@types/chai": "^4.3.20",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.19.30",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "typechain": "^8.3.2",
    "typescript": "^5.9.3"
  }
}
