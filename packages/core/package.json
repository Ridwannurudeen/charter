{
  "name": "@charter/core",
  "version": "0.1.0",
  "description": "Confidential ERC-7984 ownership registry with a trusted module ACL",
  "license": "BSD-3-Clause-Clear",
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "files": [
    "LICENSE",
    "contracts",
    "artifacts/contracts/CharterShares.sol/CharterShares.json",
    "artifacts/contracts/interfaces/ICharterModule.sol/ICharterModule.json",
    "artifacts/contracts/interfaces/ICharterModule.sol/ICharterModuleFundsRecoverable.json",
    "dist"
  ],
  "scripts": {
    "clean": "rimraf artifacts cache dist types",
    "compile": "hardhat compile",
    "build:ts": "tsc --project tsconfig.json",
    "build": "npm run compile && npm run build:ts",
    "test": "hardhat test",
    "prepack": "npm run clean && npm run build"
  },
  "dependencies": {
    "@fhevm/solidity": "0.11.1",
    "@openzeppelin/confidential-contracts": "0.5.1",
    "@openzeppelin/contracts": "5.6.1",
    "ethers": "^6.16.0"
  }
}
